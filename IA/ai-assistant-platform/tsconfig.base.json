{
  "compilerOptions": {
    "target": "ES2021",
    "lib": [
      "ES2021",
      "DOM"
    ],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "Node",
    "declaration": true,
    "baseUrl": ".",
    "paths": {
      "@vlv-ai/shared": [
        "packages/shared/src"
      ]
    }
  }
}

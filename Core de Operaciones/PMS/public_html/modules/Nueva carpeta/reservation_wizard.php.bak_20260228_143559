      });
      return target;
    }

    function snapshotMainChildState() {
      if (!childList) return;
      childList.querySelectorAll('.wizard-child-item').forEach(function (item) {
        var catalogInput = item.querySelector('.wizard-child-catalog-id');
        var parentInput = item.querySelector('.wizard-child-parent-catalog-id');
        var totalInput = item.querySelector('.wizard-child-total');
        var childId = catalogInput ? (parseInt(catalogInput.value || '0', 10) || 0) : 0;
        var parentId = parentInput ? (parseInt(parentInput.value || '0', 10) || 0) : 0;
        if (!childId) return;
        var pairKey = String(parentId) + ':' + String(childId);
        mainChildStateByPair[pairKey] = {
          total: totalInput ? String(totalInput.value || '') : ''
        };
      });
    }

    function renderMainChildRows() {
      if (!lodgingSelect || !childRow || !childList || !childTemplate) return;
      var opt = lodgingSelect.options[lodgingSelect.selectedIndex];
      var rootCatalogId = parseInt(lodgingSelect.value || '0', 10) || 0;
      var fixedTree = buildFixedChildrenTree(rootCatalogId, opt);
      var fixedChildren = flattenFixedChildrenTree(fixedTree, []).filter(function (child) {
        var childId = parseInt(child && child.id ? child.id : 0, 10) || 0;
        return childId > 0;
      });
      childList.innerHTML = '';
      if (!fixedChildren.length) {
        childRow.style.display = 'none';
        return;
      }
      childRow.style.display = 'block';
      function renderNode(child) {
        var frag = childTemplate.content.cloneNode(true);
        var item = frag.querySelector('.wizard-child-item');
        if (!item) return;
        var childId = parseInt(child.id || '0', 10) || 0;
        var childName = String((child.label || child.name || '')).trim();
        var defaultNightly = (parseInt(child.default_cents || '0', 10) || 0) / 100;
        var depth = parseInt(child.depth || 0, 10) || 0;
        var title = item.querySelector('.wizard-child-title');
        var totalInput = item.querySelector('.wizard-child-total');
        var catalogIdInput = item.querySelector('.wizard-child-catalog-id');
        var parentCatalogIdInput = item.querySelector('.wizard-child-parent-catalog-id');
        if (title) {
          var depthPrefix = depth > 0 ? new Array(depth + 1).join('\u2014 ') : '';
          title.textContent = childName !== '' ? ('Derivados ' + depthPrefix + childName) : 'Derivados';
          title.style.paddingLeft = String(depth * 16) + 'px';
        }
        item.style.marginLeft = String(depth * 12) + 'px';
        if (catalogIdInput) {
          catalogIdInput.value = String(childId);
        }
        var parentId = parseInt(child.parent_catalog_id || '0', 10) || 0;
        if (parentCatalogIdInput) {
          parentCatalogIdInput.value = String(parentId);
        }
        var pairKey = String(parentId) + ':' + String(childId);
        var saved = mainChildStateByPair[pairKey] || null;
        if (totalInput) {
          if (saved && String(saved.total || '').trim() !== '') {
            totalInput.value = String(saved.total);
          } else {
            totalInput.value = defaultNightly.toFixed(2);
          }
        }
        childList.appendChild(frag);
        if (Array.isArray(child.children) && child.children.length) {
          child.children.forEach(renderNode);
        }
      }
      fixedTree.forEach(renderNode);
      refreshChildTotals(breakdownInputs.length);
    }

    function refreshTotals(forceUpdate) {
      var sum = 0;
      breakdownInputs.forEach(function (inp) {
        sum += parseVal(inp);
      });
      var count = breakdownInputs.length;
      var avg = count ? (sum / count) : 0;
      if (avgField && (forceUpdate || document.activeElement !== avgField)) {
        avgField.value = avg.toFixed(2);
      }
      if (sumField && (forceUpdate || document.activeElement !== sumField)) {
        sumField.value = sum.toFixed(2);
      }
      if (fixedAvg) fixedAvg.value = avg.toFixed(2);
      refreshChildTotals(count);
      var grandTotal = sum;
      if (childList) {
        childList.querySelectorAll('.wizard-child-total').forEach(function (input) {
          grandTotal += parseVal(input);
        });
      }
      if (extraLodgingList) {
        extraLodgingList.querySelectorAll('.wizard-extra-lodging-total').forEach(function (input) {
          grandTotal += parseVal(input);
        });
        extraLodgingList.querySelectorAll('.wizard-extra-child-total-field').forEach(function (input) {
          grandTotal += parseVal(input);
        });
      }
      var selectedConcepts = 0;
      if (lodgingSelect && String(lodgingSelect.value || '').trim() !== '') {
        selectedConcepts++;
      }
      if (extraLodgingList) {
        extraLodgingList.querySelectorAll('.wizard-extra-lodging-select').forEach(function (select) {
          if (String(select.value || '').trim() !== '') {
            selectedConcepts++;
          }
        });
      }
      if (grandWrap) {
        grandWrap.style.display = selectedConcepts > 1 ? 'block' : 'none';
      }
      if (grandField) {
        grandField.value = grandTotal.toFixed(2);
      }
      return {sum:sum,count:count,avg:avg};
    }

    function applyAvgToBreakdown() {
      if (!avgField || !breakdownInputs.length) return;
      var avg = parseVal(avgField, true);
      if (avg === null) return;
      breakdownInputs.forEach(function (inp) {
        inp.value = avg.toFixed(2);
      });
      refreshTotals();
    }

    function applySumToBreakdown() {
      if (!sumField || !breakdownInputs.length) return;
      var total = parseVal(sumField, true);
      if (total === null) return;
      var count = breakdownInputs.length;
      var avg = count ? (total / count) : 0;
      breakdownInputs.forEach(function (inp) {
        inp.value = avg.toFixed(2);
      });
      refreshTotals();
    }

    function setActiveTab() {
      refreshTotals(true);
    }

    breakdownInputs.forEach(function (inp) {
      inp.addEventListener('input', refreshTotals);
    });
    function bindEditableTotals(field, handler) {
      if (!field) return;
      field.addEventListener('input', handler);
      field.addEventListener('blur', handler);
      field.addEventListener('change', handler);
      field.addEventListener('keydown', function (ev) {
        if (ev.key === 'Enter') {
          ev.preventDefault();
          handler();
        }
      });
    }

    bindEditableTotals(avgField, function () {
      if (isSyncingTotals) return;
      isSyncingTotals = true;
      applyAvgToBreakdown();
      isSyncingTotals = false;
    });
    bindEditableTotals(sumField, function () {
      if (isSyncingTotals) return;
      isSyncingTotals = true;
      applySumToBreakdown();
      isSyncingTotals = false;
    });
    if (childList) {
      childList.addEventListener('input', function (event) {
        var target = event.target;
        if (!target) return;
        if (target.classList.contains('wizard-child-total')) {
          refreshTotals();
        }
      });
    }

    setActiveTab();

    function syncChildFromSelection() {
      snapshotMainChildState();
      renderMainChildRows();
      refreshTotals(true);
    }

    var addExtraLodgingBtn = document.getElementById('wizard-add-lodging-concept');
    var extraLodgingList = document.getElementById('wizard-extra-lodging-list');
    var extraLodgingTpl = document.getElementById('wizard-extra-lodging-template');
    var initialExtraConcepts = <?php echo json_encode(array_values($wizardExtraLodgingConcepts), JSON_UNESCAPED_UNICODE); ?>;
    var initialExtraTotals = <?php echo json_encode(array_values($wizardExtraLodgingTotals), JSON_UNESCAPED_UNICODE); ?>;
    var initialExtraChildrenJson = <?php echo json_encode(array_values($wizardExtraChildrenJson), JSON_UNESCAPED_UNICODE); ?>;

    function getAllLodgingSelects() {
      var selects = [];
      if (lodgingSelect) selects.push(lodgingSelect);
      if (extraLodgingList) {
        extraLodgingList.querySelectorAll('.wizard-extra-lodging-select').forEach(function (select) {
          selects.push(select);
        });
      }
      return selects;
    }

    function isConceptUsedElsewhere(currentSelect, value) {
      if (!value) return false;
      var used = false;
      getAllLodgingSelects().forEach(function (select) {
        if (used || select === currentSelect) return;
        if (String(select.value || '') === String(value)) {
          used = true;
        }
      });
      return used;
    }

    function refreshUniqueLodgingOptions() {
      var selectedMap = {};
      getAllLodgingSelects().forEach(function (select) {
        var val = String(select.value || '');
        if (!val) return;
        selectedMap[val] = true;
      });
      getAllLodgingSelects().forEach(function (select) {
        var ownValue = String(select.value || '');
        Array.prototype.forEach.call(select.options, function (opt) {
          var optVal = String(opt.value || '');
          if (!optVal) {
            opt.disabled = false;
            return;
          }
          opt.disabled = !!selectedMap[optVal] && optVal !== ownValue;
        });
      });
    }

    function bindExtraRow(row) {
      if (!row) return;
      var select = row.querySelector('.wizard-extra-lodging-select');
      var totalInput = row.querySelector('.wizard-extra-lodging-total');
      var childWrap = row.querySelector('.wizard-extra-child-wrap');
      var childList = row.querySelector('.wizard-extra-child-list');
      var childJsonInput = row.querySelector('.wizard-extra-children-json');
      var childInfo = row.querySelector('.wizard-extra-child-info');
      var extraChildStateByCatalog = {};
      if (childJsonInput && childJsonInput.value) {
        try {
          var parsedState = JSON.parse(childJsonInput.value);
          if (Array.isArray(parsedState)) {
            parsedState.forEach(function (child) {
              var childId = parseInt(child && child.catalog_id ? child.catalog_id : 0, 10) || 0;
              if (!childId) return;
              var parentId = parseInt(child && child.parent_catalog_id ? child.parent_catalog_id : 0, 10) || 0;
              var pairKey = String(parentId) + ':' + String(childId);
              extraChildStateByCatalog[pairKey] = {
                total: child && child.total_cents != null ? (Number(child.total_cents) / 100).toFixed(2) : ''
              };
            });
          }
        } catch (e) {}
      }

      function parseExtraValue(raw) {
        var normalized = normalizeNumber(raw);
        if (normalized === '' || normalized === '-' || normalized === '.' || normalized === '-.') return 0;
        var value = parseFloat(normalized);
        return isNaN(value) ? 0 : value;
      }

      function snapshotExtraChildState() {
        if (!childList) return;
        childList.querySelectorAll('.wizard-extra-child-item').forEach(function (item) {
          var childIdInput = item.querySelector('.wizard-extra-child-catalog-id');
          var childParentIdInput = item.querySelector('.wizard-extra-child-parent-catalog-id');
          var childTotalInput = item.querySelector('.wizard-extra-child-total-field');
          var childId = childIdInput ? (parseInt(childIdInput.value || '0', 10) || 0) : 0;
          var parentId = childParentIdInput ? (parseInt(childParentIdInput.value || '0', 10) || 0) : 0;
          if (!childId) return;
          var pairKey = String(parentId) + ':' + String(childId);
          extraChildStateByCatalog[pairKey] = {
            total: childTotalInput ? String(childTotalInput.value || '') : ''
          };
        });
      }

      function updateExtraChildrenJson() {
        if (!childJsonInput || !childList) return;
        var payload = [];
        childList.querySelectorAll('.wizard-extra-child-item').forEach(function (item) {
          var childIdInput = item.querySelector('.wizard-extra-child-catalog-id');
          var childParentIdInput = item.querySelector('.wizard-extra-child-parent-catalog-id');
          var childTotalInput = item.querySelector('.wizard-extra-child-total-field');
          var childId = childIdInput ? (parseInt(childIdInput.value || '0', 10) || 0) : 0;
          var parentId = childParentIdInput ? (parseInt(childParentIdInput.value || '0', 10) || 0) : 0;
          if (!childId) return;
          var totalVal = parseExtraValue(childTotalInput ? childTotalInput.value : '');
          var totalCents = Math.round(totalVal * 100);
          payload.push({
            catalog_id: childId,
            parent_catalog_id: parentId,
            total_cents: totalCents > 0 ? totalCents : 0
          });
        });
        childJsonInput.value = JSON.stringify(payload);
      }

      function renderExtraChildRows() {
        if (!select || !childWrap || !childList) return;
        var opt = select.options[select.selectedIndex];
        var rootCatalogId = parseInt(select.value || '0', 10) || 0;
        var fixedTree = buildFixedChildrenTree(rootCatalogId, opt);
        var fixedChildren = flattenFixedChildrenTree(fixedTree, []).filter(function (child) {
          var childId = parseInt(child && child.id ? child.id : 0, 10) || 0;
          return childId > 0;
        });
        childList.innerHTML = '';
        if (!fixedChildren.length) {
          childWrap.style.display = 'none';
          if (childInfo) childInfo.textContent = '';
          if (childJsonInput) childJsonInput.value = '[]';
          return;
        }
        childWrap.style.display = 'block';
        if (childInfo) childInfo.textContent = '';
        function renderNode(child) {
          var childId = parseInt(child.id || '0', 10) || 0;
          var childName = String((child.label || child.name || '')).trim();
          var defaultTotal = (parseInt(child.default_cents || '0', 10) || 0) / 100;
          var depth = parseInt(child.depth || 0, 10) || 0;
          var parentId = parseInt(child.parent_catalog_id || '0', 10) || 0;
          var pairKey = String(parentId) + ':' + String(childId);
          var saved = extraChildStateByCatalog[pairKey] || extraChildStateByCatalog[childId] || null;
          var total = saved && String(saved.total || '').trim() !== '' ? parseExtraValue(saved.total) : defaultTotal;
          var block = document.createElement('div');
          block.className = 'payment-block wizard-extra-child-item';
          block.style.marginTop = '10px';
          block.style.marginLeft = String(depth * 16) + 'px';
          block.innerHTML =
            '<div class="payment-row-title">' + (childName !== '' ? ('Derivados ' + (depth > 0 ? new Array(depth + 1).join('\u2014 ') : '') + childName) : 'Derivados') + '</div>' +
            '<div class="form-grid grid-1 wizard-extra-child-grid">' +
              '<label>Total' +
                '<input type="text" inputmode="decimal" autocomplete="off" class="wizard-extra-child-total-field" placeholder="0.00">' +
              '</label>' +
            '</div>' +
            '<input type="hidden" class="wizard-extra-child-catalog-id" value="' + String(childId) + '">' +
            '<input type="hidden" class="wizard-extra-child-parent-catalog-id" value="' + String(parseInt(child.parent_catalog_id || '0', 10) || 0) + '">';
          var totalInput = block.querySelector('.wizard-extra-child-total-field');
          if (totalInput) totalInput.value = total.toFixed(2);
          if (totalInput) {
            totalInput.addEventListener('input', function () {
              updateExtraChildrenJson();
              refreshTotals(true);
            });
            totalInput.addEventListener('blur', function () {
              var val = parseExtraValue(totalInput.value);
              totalInput.value = val.toFixed(2);
              updateExtraChildrenJson();
              refreshTotals(true);
            });
          }
          childList.appendChild(block);
          if (Array.isArray(child.children) && child.children.length) {
            child.children.forEach(renderNode);
          }
        }
        fixedTree.forEach(renderNode);
        updateExtraChildrenJson();
      }

      function update() {
        if (!select) return;
        snapshotExtraChildState();
        renderExtraChildRows();
        refreshUniqueLodgingOptions();
        refreshTotals(true);
      }

      if (select) {
        select.addEventListener('change', function () {
          var selected = String(select.value || '');
          if (selected && isConceptUsedElsewhere(select, selected)) {
            select.value = '';
          }
          update();
        });
      }
      if (totalInput) {
        totalInput.addEventListener('input', function () {
          update();
        });
      }
      update();
    }

    function addExtraRow(conceptId, totalValue, childrenJsonValue) {
      if (!extraLodgingList || !extraLodgingTpl) return;
      var frag = extraLodgingTpl.content.cloneNode(true);
      var row = frag.querySelector('.wizard-extra-lodging-row');
      if (row) {
        var select = row.querySelector('.wizard-extra-lodging-select');
        var totalInput = row.querySelector('.wizard-extra-lodging-total');
        var childrenJsonInput = row.querySelector('.wizard-extra-children-json');
        if (select && conceptId) {
          var desiredConcept = String(conceptId);
          if (!isConceptUsedElsewhere(select, desiredConcept)) {
            select.value = desiredConcept;
          }
        }
        if (totalInput && totalValue !== undefined && totalValue !== null && String(totalValue) !== '') {
          totalInput.value = String(totalValue);
        }
        if (childrenJsonInput) {
          childrenJsonInput.value = (childrenJsonValue !== undefined && childrenJsonValue !== null && String(childrenJsonValue) !== '')
            ? String(childrenJsonValue)
            : '[]';
        }
      }
      extraLodgingList.appendChild(frag);
      var appendedRows = extraLodgingList.querySelectorAll('.wizard-extra-lodging-row');
      var lastRow = appendedRows.length ? appendedRows[appendedRows.length - 1] : null;
      bindExtraRow(lastRow);
      refreshUniqueLodgingOptions();
    }

    if (lodgingSelect) {
      lodgingSelect.addEventListener('change', function () {
        var selected = String(lodgingSelect.value || '');
        if (selected && isConceptUsedElsewhere(lodgingSelect, selected)) {
          lodgingSelect.value = '';
        }
        syncChildFromSelection();
        refreshUniqueLodgingOptions();
        bindWizardFieldStates();
      });
      syncChildFromSelection();
      refreshUniqueLodgingOptions();
      bindWizardFieldStates();
    }

    if (addExtraLodgingBtn && extraLodgingList && extraLodgingTpl) {
      if (Array.isArray(initialExtraConcepts) && initialExtraConcepts.length) {
        initialExtraConcepts.forEach(function (conceptId, idx) {
          var totalVal = Array.isArray(initialExtraTotals) ? initialExtraTotals[idx] : '';
          var childrenJsonVal = Array.isArray(initialExtraChildrenJson) ? initialExtraChildrenJson[idx] : '[]';
          addExtraRow(conceptId, totalVal, childrenJsonVal);
        });
      }
      addExtraLodgingBtn.addEventListener('click', function () {
        addExtraRow('', '', '[]');
        bindWizardFieldStates();
      });
      extraLodgingList.addEventListener('click', function (ev) {
        var btn = ev.target.closest('.js-remove-extra-lodging');
        if (!btn) return;
        var row = btn.closest('.wizard-extra-lodging-row');
        if (row) row.remove();
        refreshUniqueLodgingOptions();
        refreshTotals(true);
        bindWizardFieldStates();
      });
    }

  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initWizard);
  } else {
    initWizard();
  }
})();
</script>

    $avgCents = ($count > 0) ? (int)round($sumCents / $count) : 0;

    // guest phone combine
    $guestPhoneCombined = trim($wizard['guest_phone']);
    if ($guestPhoneCombined !== '' && substr($guestPhoneCombined, 0, 1) !== '+') {
        $guestPhoneCombined = trim($wizard['guest_prefix'] . ' ' . $guestPhoneCombined);

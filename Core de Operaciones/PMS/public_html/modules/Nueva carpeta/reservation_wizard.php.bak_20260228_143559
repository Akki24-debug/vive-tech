        $originKey = 'ota:' . $otaId;
        if (isset($seen[$originKey])) {
            continue;
        }
        $seen[$originKey] = true;
        $rows[] = array(
            'origin_key' => $originKey,
            'origin_label' => $otaName,
            'source_id' => 0,
            'ota_account_id' => $otaId,
            'source_value' => $otaSource
        );
    }

    if (!$rows) {
        $rows[] = array(
            'origin_key' => 'source:0',
            'origin_label' => 'Directo',
            'source_id' => 0,
            'ota_account_id' => 0,
            'source_value' => 'Directo'
        );
    }

    return $rows;
}


// Validacin paso 1 -> preparar paso 2
if ($step === 2) {
    if ($wizard['property_code'] === '' || $wizard['room_code'] === '' || $wizard['check_in'] === '' || $wizard['check_out'] === '' || $wizard['category_code'] === '') {

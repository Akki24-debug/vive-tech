$wizardOtaAccountId = isset($wizardOriginRowCurrent['ota_account_id']) ? (int)$wizardOriginRowCurrent['ota_account_id'] : 0;
if (!isset($phonePrefixDialMap[$wizard['guest_prefix']])) {

            if ($newReservationId > 0) {
                if ($newFolioId <= 0) {
                    $newFolioId = rw_get_latest_folio_id($newReservationId);
                }
                if ($newFolioId > 0 && $mainChildSpecs) {
                    rw_apply_main_child_totals(
                        $newReservationId,
                        $newFolioId,
                        $lodgingConceptId,
                        $mainChildSpecs,

    } else {
        try {
            $dtIn  = new DateTime($wizard['check_in']);
            $dtOut = new DateTime($wizard['check_out']);
            $diff  = (int)$dtIn->diff($dtOut)->format('%r%a');
            $nights = $diff > 0 ? $diff : 0;
